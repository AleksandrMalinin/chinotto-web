{
  "headers": [
    {
      "source": "/.well-known/apple-app-site-association",
      "headers": [{ "key": "Content-Type", "value": "application/json" }]
    }
  ],
  "rewrites": [
    { "source": "/privacy", "destination": "/privacy/index.html" },
    { "source": "/privacy/", "destination": "/privacy/index.html" },
    { "source": "/manifesto", "destination": "/index.html" },
    { "source": "/showcase", "destination": "/index.html" },
    {
      "source": "/((?!assets/|\\.well-known/|og-image\\.png|favicon\\.ico|robots\\.txt|sitemap\\.xml|apple-touch-icon\\.png|favicon-32x32\\.png|favicon-16\\.png|favicon-32\\.png|favicon-light-16\\.png|favicon-light-32\\.png|favicon\\.svg).*)",
      "destination": "/index.html"
    }
  ]
}
